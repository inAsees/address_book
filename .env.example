# Database connection URL
# SQLite file path;
DATABASE_URL=sqlite:///./address_book.db

# API version prefix for all endpoints
API_V1_PREFIX=/api/v1

# Name of the project (used in API documentation)
PROJECT_NAME="Address Book API"

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output format: "text" for human-readable, "json" for structured logs
LOG_FORMAT=text

# Default unit for distance measurements (km or mi)
DEFAULT_DISTANCE_UNIT=km

# Optional: Path to log file (if not set, logs only go to console)
# Directory must exist; the app will create the file if needed.
LOG_FILE=app/logs/app.log